{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/ghost",
      "dest": "/api/ghost.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}